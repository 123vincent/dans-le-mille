      <title>Calculateur — Efficacité de l&#39;arc</title>
      <link>http://localhost:1313/calculateurs/efficacite-arc/</link>
      <pubDate>Mon, 01 Jan 2024 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/calculateurs/efficacite-arc/</guid>
      <description>&lt;style&gt;
.calc-section {
    margin-bottom: 2.5rem;
}
.calc-form {
    background: var(--code-bg, #f2f2f2);
    border: 1px solid var(--border, #ddd);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
}
.calc-form label {
    display: block;
    margin-top: 1rem;
    font-weight: 600;
    font-size: 0.95rem;
}
.calc-form .unite {
    font-weight: 400;
    color: var(--secondary, #666);
    font-size: 0.85rem;
}
.calc-form input[type=&#34;text&#34;] {
    display: block;
    width: 100%;
    max-width: 480px;
    margin-top: 0.3rem;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--border, #ccc);
    border-radius: 4px;
    font-size: 1rem;
    box-sizing: border-box;
}
.calc-form input.input-error {
    border-color: #c0392b;
}
.calc-form .error {
    margin-top: 0.5rem;
    color: #c0392b;
    font-size: 0.88rem;
    min-height: 1.2em;
}
.calc-form button {
    margin-top: 1.2rem;
    padding: 0.5rem 1.2rem;
    background: var(--primary, #333);
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
}
.calc-form button:hover {
    opacity: 0.85;
}

 
.calc-output {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.5s ease, opacity 0.4s ease;
    background: var(--entry, #fafafa);
    border: 1px solid var(--border, #ddd);
    border-radius: 8px;
    margin-bottom: 2rem;
}
.calc-output.visible {
    max-height: 2000px;
    opacity: 1;
}
.calc-output-inner {
    padding: 1.2rem 1.5rem;
}
.btclose {
    display: inline-block;
    float: right;
    cursor: pointer;
    font-size: 1.2rem;
    line-height: 1;
    color: #c0392b;
    user-select: none;
}
.btclose::before {
    content: &#34;✕&#34;;
}
.calc-output table {
    border-collapse: collapse;
    width: 100%;
    margin-top: 0.5rem;
    font-size: 0.9rem;
}
.calc-output th, .calc-output td {
    border: 1px solid var(--border, #ccc);
    padding: 0.3rem 0.6rem;
    text-align: right;
}
.calc-output th {
    background: var(--entry, #eee);
    text-align: center;
}
.calc-output dl { margin: 0.3rem 0; }
.calc-output dd { margin-left: 1rem; }

 
.calc-h2 {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 1.2rem 0 0.6rem 0;
    line-height: 1.3;
}
.calc-h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1rem 0 0.4rem 0;
    line-height: 1.3;
}
.chart-wrapper {
    position: relative;
    max-width: 560px;
    margin-top: 1rem;
}
&lt;/style&gt;


&lt;div class=&#34;calc-section&#34;&gt;
&lt;form name=&#34;form_1&#34; id=&#34;form_1&#34; autocomplete=&#34;off&#34; class=&#34;calc-form&#34;&gt;
