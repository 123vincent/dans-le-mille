      <guid>http://localhost:1313/calculateurs/viseur-scope-oeilleton/</guid>
      <description>&lt;style&gt;
 
.calc-scope-drawing-wrap {
    width: 60%;
    max-width: 440px;
}
#drawing {
    width: 100%;
    position: relative;
    padding-bottom: 100%;  
}
#container {
    position: absolute;
    left: 0; top: 0;
    width: 100%; height: 100%;
    background: #fff;
    border: 1px solid var(--border, #ccc);
}

 
.calc-scope-form {
    margin-top: 1.2em;
    padding: 30px 20px;
}
.calc-scope-form label.field-label {
    display: block;
    margin-top: 10px;
    font-weight: 700;
    cursor: default;
}
.calc-scope-form .unite {
    font-weight: 400;
    color: var(--secondary, #666);
    font-size: 0.85rem;
}
.calc-scope-form input[type=&#34;text&#34;],
.calc-scope-form select {
    display: block;
    width: 100%;
    max-width: 480px;
    margin: 5px 0 0;
    padding: 8px 7px;
    border: 1px solid #0885C7;
    border-radius: 5px;
    font-size: inherit;
    box-sizing: border-box;
    background: #f8f8f8;
}
.calc-scope-form input[type=&#34;text&#34;]:focus {
    outline: 0;
    box-shadow: inset 0 1px 1px rgba(0,0,0,.075), 0 0 6px #0885C7;
}
.calc-scope-form .error-msg {
    background: #FF4200;
    color: #fff;
    border-radius: 5px;
    padding: 10px 8px;
    margin: 20px 0;
    font-size: 0.9rem;
    display: none;
}
.calc-scope-form .error-msg.visible { display: block; }

.calc-scope-form button {
    display: block;
    margin-top: 20px;
    padding: 8px 15px;
    font-size: 1.1rem;
    font-weight: 700;
    background: linear-gradient(to bottom, #ffba00, #ffd564);
    border: 1px solid #9B7100;
    border-radius: 5px;
    cursor: pointer;
    color: #000;
}
.calc-scope-form button:hover { background-position: 0 -30px; }

.calc-scope-form ul.radio {
    list-style: none;
    padding: 0;
    margin-top: 20px;
}
.calc-scope-form ul.radio input {
    display: inline-block;
    width: auto;
    margin: 0;
    border: 0;
    background: none;
    box-shadow: none;
    padding: 0;
}

 
.tabs {
    position: relative;
    margin-top: 20px;
}
.tabs input[name=&#34;tab&#34;] { display: none; }

.tab-label {
    text-transform: uppercase;
    font-size: 14px;
    color: #555;
    font-weight: 700;
    display: inline-block;
    width: 120px;
    padding: 5px 0;
    margin: 0;
    text-align: center;
    background: #ccc;
    border: 1px solid #bbb;
    border-radius: 10px 10px 0 0;
    border-bottom: 0;
    cursor: pointer;
}
.tab-label:hover { background: #eee; color: #666; }

 
#tab-B:checked ~ label[for=&#34;tab-B&#34;],
#tab-B:not(:checked) ~ #tab-C:not(:checked) ~ label[for=&#34;tab-A&#34;],
#tab-C:checked ~ label[for=&#34;tab-C&#34;] {
    background: #eee;
}
#tab-B:checked ~ label[for=&#34;tab-B&#34;]::after,
#tab-B:not(:checked) ~ #tab-C:not(:checked) ~ label[for=&#34;tab-A&#34;]::after,
#tab-C:checked ~ label[for=&#34;tab-C&#34;]::after {
    position: absolute;
    content: &#34;&#34;;
    margin: 5px 0 0;
    width: 118px;
    height: 5px;
    display: block;
    background: #eee;
}

.tab {
